@page
@model IndexModel
@{
    ViewData["Title"] = "Главная";
}

<style>

    body {
        margin: 0;
        background: #f5f7fb;
        font-family: "Segoe UI", Arial, sans-serif;
        color: #111;
    }

    .page {
        max-width: 1400px;
        margin: 0 auto;
        padding: 30px 20px 80px;
    }

    /* =========================
                   HERO
        ========================= */
    .hero-modern {
        background: linear-gradient(135deg, #1c41b0, #2f6bff);
        color: #fff;
        padding: 70px 40px;
        border-radius: 24px;
        margin: 20px auto;
        max-width: 1310px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

        .hero-modern h1 {
            font-size: 40px;
            font-weight: 800;
            margin: 0;
        }

        /* Подзаголовок */
        .hero-modern p:first-of-type {
            font-size: 22px;
            font-weight: 600;
            margin-top: 10px;
        }

        /* Основной текст */
        .hero-modern p:last-of-type {
            font-size: 18px;
            opacity: 0.9;
            max-width: 900px;
            margin-top: 10px;
            line-height: 1.6;
        }

    /* =========================
                   СЕКЦИИ
        ========================= */
    .section {
        margin-top: 30px;
    }

    .section-title {
        font-size: 34px;
        font-weight: 900;
        margin-bottom: 25px;
        color: #111;
        text-align: left;
        padding-left: 5px;
    }

    /* =========================
                   GRID
        ========================= */
    .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
    }

    .section-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #e7eef8;
        box-shadow: 0 6px 18px rgba(0,0,0,0.05);
        transition: 0.2s ease;
    }

        .section-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 14px 35px rgba(0,0,0,0.12);
        }

    .section-img {
        width: 100%;
        height: 240px;
        object-fit: cover;
    }

    .section-body {
        padding: 16px;
        text-align: center;
    }

        .section-body h5 {
            font-weight: 800;
            font-size: 20px;
            margin-bottom: 6px;
        }

        .section-body p {
            font-size: 16px;
            color: #6b7280;
            margin-bottom: 10px;
        }

    /* =========================
                   PROFILE
        ========================= */
    .profile-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .profile-card {
        background: #fff;
        border-radius: 16px;
        padding: 22px;
        text-align: center;
        border: 1px solid #e7eef8;
        box-shadow: 0 6px 18px rgba(0,0,0,0.05);
        transition: 0.2s ease;
    }

        .profile-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 14px 30px rgba(0,0,0,0.1);
        }

    .profile-icon {
        font-size: 38px;
        margin-bottom: 8px;
    }

    .profile-card h5 {
        font-weight: 700;
        font-size: 20px;
        color: #111;
    }

    .profile-card p {
        font-size: 16px; /* 🔥 исправили */
        color: #6b7280;
    }

    /* =========================
                   BUTTON
        ========================= */
    .btn-modern {
        display: block;
        width: 100%;
        margin-top: 12px;
        padding: 14px 16px;
        background: #3884ff;
        color: #fff;
        border-radius: 12px;
        text-decoration: none;
        font-size: 18px;
        font-weight: 600;
        text-align: center;
        transition: 0.2s;
    }

        .btn-modern:hover {
            background: #0041aa;
            transform: translateY(-2px);
            color: #fff;
        }

   
    

    
</style>

<!-- HERO -->
<div class="hero-modern">
    <h1>Центр общения старшего поколения</h1>
    <p>отделение по Саратовской области</p>
    <p>
        Поддержка людей «серебряного» возраста – одно из приоритетных направлений работы центров общения старшего поколения
    </p>
</div>

<div class="page">

    <!-- РАЗДЕЛЫ -->
    <div class="section">
        <div class="section-title">Разделы</div>

        <div class="grid">

            <div class="section-card">
                <img class="section-img" src="/Photo/Главная/рег11.png" />
                <div class="section-body">
                    <h5>Регистрация</h5>
                    <p>Создание аккаунта</p>
                    <a class="btn-modern" asp-area="Identity" asp-page="/Account/Register">Зарегистрироваться</a>
                </div>
            </div>

            <div class="section-card">
                <img class="section-img" src="/Photo/Главная/онас122.png" />
                <div class="section-body">
                    <h5>О нас</h5>
                    <p>Информация о центре и его миссии</p>
                    <a class="btn-modern" asp-page="/Account/CenterInfo">Перейти</a>
                </div>
            </div>

            <div class="section-card">
                <img class="section-img" src="/Photo/Главная/мер1.png" />
                <div class="section-body">
                    <h5>Мероприятия</h5>
                    <p>Встречи, клубы и активности</p>
                    <a class="btn-modern" asp-page="/Account/Meropriatia">Перейти</a>
                </div>
            </div>

            <div class="section-card">
                <img class="section-img" src="/Photo/Главная/нов1.png" />
                <div class="section-body">
                    <h5>Новости</h5>
                    <p>События центра</p>
                    <a class="btn-modern" asp-page="/Account/News">Перейти</a>
                </div>
            </div>

            <div class="section-card">
                <img class="section-img" src="/Photo/Главная/тес3.png" />
                <div class="section-body">
                    <h5>Тест</h5>
                    <p>Подбор интересов</p>
                    <a class="btn-modern" asp-page="/Account/HobbyTest">Пройти</a>
                </div>
            </div>

            <div class="section-card">
                <img class="section-img" src="/Photo/Главная/мош1.png" />
                <div class="section-body">
                    <h5>Безопасность</h5>
                    <p>Защита от мошенников</p>
                    <a class="btn-modern" asp-page="/Account/AntiMoshenniki">Открыть</a>
                </div>
            </div>

        </div>
    </div>

    <!-- ПРОФИЛЬ -->
    <div class="section">
        <div class="section-title">Профиль</div>

        <div class="profile-grid">

            @if (!(User?.Identity?.IsAuthenticated ?? false))
            {
                <div class="profile-card">
                    <div class="profile-icon">👤</div>
                    <h5>Вход</h5>
                    <p>Доступ к сервисам</p>
                    <a class="btn-modern" asp-area="Identity" asp-page="/Account/Login">Войти</a>
                </div>

                <div class="profile-card">
                    <div class="profile-icon">📝</div>
                    <h5>Регистрация</h5>
                    <p>Создание аккаунта</p>
                    <a class="btn-modern" asp-area="Identity" asp-page="/Account/Register">Регистрация</a>
                </div>
            }
            else
            {
                <div class="profile-card">
                    <div class="profile-icon">👤</div>
                    <h5>Профиль</h5>
                    <p>@User.Identity.Name</p>
                    <a class="btn-modern" asp-area="Identity" asp-page="/Account/Manage/Index">Открыть</a>
                </div>

                <div class="profile-card">
                    <div class="profile-icon">⚙️</div>
                    <h5>Аккаунт</h5>
                    <p>Настройки профиля</p>
                    <a class="btn-modern" asp-area="Identity" asp-page="/Account/Manage/Index">Перейти</a>
                </div>
            }

        </div>
    </div>

</div>