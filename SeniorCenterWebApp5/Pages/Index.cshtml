</section> *@

@* @page
@model IndexModel
@{
    ViewData["Title"] = "Главная";
    Layout = "_Layout";
}

<style>
    /* =========================
            ОБЩИЙ СТИЛЬ СТРАНИЦЫ
        ========================= */
    body {
        background: #f5f7fb;
    }

    .container {
        max-width: 1200px;
    }

    /* =========================
            HERO (как портал)
        ========================= */
    .hero-modern {
        background: linear-gradient(135deg, #1c41b0, #3f6ef7);
        color: #fff;
        padding: 50px 40px;
        border-radius: 24px;
        margin-top: 20px;
        box-shadow: 0 10px 40px rgba(28, 65, 176, 0.25);
    }

        .hero-modern h1 {
            font-weight: 800;
            font-size: 2.2rem;
            margin-bottom: 10px;
        }

        .hero-modern p {
            font-size: 1.1rem;
            opacity: 0.9;
        }

    /* =========================
            ПРОФИЛЬ БЛОК
        ========================= */
    .profile-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-top: 25px;
    }

    @@media (max-width: 768px) {
        .profile-grid {
            grid-template-columns: 1fr;
        }
    }

    .profile-card {
        background: #fff;
        border-radius: 18px;
        padding: 22px;
        text-align: center;
        box-shadow: 0 8px 25px rgba(0,0,0,0.06);
        transition: 0.25s;
        border: 1px solid #eef1f6;
    }

        .profile-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 14px 35px rgba(0,0,0,0.1);
        }

    .profile-icon {
        font-size: 34px;
        margin-bottom: 10px;
    }

    .profile-card h5 {
        font-weight: 700;
        margin-bottom: 6px;
    }

    .profile-card p {
        color: #6b7280;
        font-size: 0.95rem;
        margin-bottom: 15px;
    }

    /* =========================
            РАЗДЕЛЫ (КАРТОЧКИ)
        ========================= */
    .section-title {
        font-size: 1.6rem;
        font-weight: 800;
        margin: 40px 0 20px;
    }

    .section-card {
        background: #fff;
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid #eef1f6;
        box-shadow: 0 8px 25px rgba(0,0,0,0.05);
        transition: 0.25s;
        height: 100%;
    }

        .section-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 18px 40px rgba(0,0,0,0.12);
        }

    .section-img {
        width: 100%;
        height: 160px;
        object-fit: cover;
    }

    .section-body {
        padding: 18px;
    }

        .section-body h5 {
            font-weight: 800;
            margin-bottom: 6px;
        }

        .section-body p {
            color: #6b7280;
            font-size: 0.95rem;
            min-height: 48px;
        }

    .btn-modern {
        background: #1c41b0;
        color: #fff;
        border-radius: 10px;
        padding: 8px 14px;
        display: inline-block;
        text-decoration: none;
        font-weight: 500;
    }

        .btn-modern:hover {
            background: #153084;
            color: #fff;
        }

</style>

<!-- =========================
    HERO
========================= -->
<div class="hero-modern">
    <h1>Центр общения старшего поколения</h1>
    <p>Саратовская область • цифровая платформа для общения, развития и поддержки</p>
</div>

<!-- =========================
    ПРОФИЛЬ
========================= -->
<section class="profile-grid">

    @if (!(User?.Identity?.IsAuthenticated ?? false))
    {
        <div class="profile-card">
            <div class="profile-icon">👤</div>
            <h5>Вход</h5>
            <p>Доступ к личному кабинету</p>
            <a class="btn-modern w-100" asp-area="Identity" asp-page="/Account/Login">Войти</a>
        </div>

        <div class="profile-card">
            <div class="profile-icon">📝</div>
            <h5>Регистрация</h5>
            <p>Создайте аккаунт за 1 минуту</p>
            <a class="btn-modern w-100" asp-area="Identity" asp-page="/Account/Register">Регистрация</a>
        </div>
    }
    else
    {
        <div class="profile-card">
            <div class="profile-icon">👤</div>
            <h5>Профиль</h5>
            <p>@User.Identity.Name</p>
            <a class="btn-modern w-100" asp-area="Identity" asp-page="/Account/Manage/Index">Открыть</a>
        </div>

        <div class="profile-card">
            <div class="profile-icon">⚙️</div>
            <h5>Аккаунт</h5>
            <p>Настройки профиля</p>
            <a class="btn-modern w-100" asp-area="Identity" asp-page="/Account/Manage/Index">Перейти</a>
        </div>
    }

</section>

<!-- =========================
    РАЗДЕЛЫ
========================= -->
<div class="section-title">Разделы портала</div>

<section class="row g-4">

    <!-- О НАС -->
    <div class="col-12 col-md-6 col-lg-4">
        <div class="section-card">
            <img class="section-img" src="/photo/about.jpg" />
            <div class="section-body">
                <h5>О нас</h5>
                <p>Информация о центре, целях и развитии проекта.</p>
                <a class="btn-modern" asp-page="/Account/CenterInfo">Перейти</a>
            </div>
        </div>
    </div>

    <!-- МЕРОПРИЯТИЯ -->
    <div class="col-12 col-md-6 col-lg-4">
        <div class="section-card">
            <img class="section-img" src="/photo/events.jpg" />
