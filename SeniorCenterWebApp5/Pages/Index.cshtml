@* 
@page
@model IndexModel
@{
    ViewData["Title"] = "Главная";
    Layout = "_Layout";
}

<!-- Героический блок с фоном, заголовком и CTA -->
<div class="hero bg-light text-center py-5 position-relative overflow-hidden">
    <!-- Используем Bootstrap классы для фона и позиционирования -->
    <div class="hero-inner mx-auto max-width-1100 px-4">
        <!-- Центрированный внутренний контейнер с максимальной шириной -->
        <div class="card-hero p-4 shadow rounded">
            <h1 class="display-4 fw-bold mb-3">Центр общения <span class="text-primary">старшего поколения</span></h1>
            <!-- Заголовок с выделением цвета -->
            <div class="subtitle mb-4 fs-4 text-muted">отделение по Саратовской области</div>
            <!-- Подзаголовок -->

            <p class="lead mb-4">
                
                Поддержка людей «серебряного» возраста – одно из приоритетных направлений работы центров общения старшего поколения.
                
            </p>

            <!-- Кнопки CTA (регистрация, вход, выход) -->
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                @if (!(User?.Identity?.IsAuthenticated ?? false))
                {
                    <!-- Если пользователь не авторизован -->
                    <a class="btn btn-primary btn-lg" asp-area="Identity" asp-page="/Account/Register">Зарегистрироваться</a>
                    <a class="btn btn-outline-secondary btn-lg" asp-area="Identity" asp-page="/Account/Login">Войти</a>
                }
                else
                {
                    <!-- Если пользователь авторизован -->
                    <!-- Можно добавить персональные ссылки, например, профиль -->
                    <a class="btn btn-outline-primary btn-lg" asp-area="Identity" asp-page="/Account/Register">Профиль</a>
     /*поменяит мб*/
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-lg">Выйти</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<!-- Основные информационные блоки с иконками и изображениями -->
<section class="container mt-5">
    <div class="row g-4">
        <!-- Блок 1: преимущества или особенности сайта -->
        <div class="col-md-6">
            <div class="card h-100 p-4 shadow-sm rounded border-0">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:50px; height:50px;">
                        <i class="bi bi-people-fill fs-4"></i>
                        <!-- Иконка Bootstrap Icons -->
                    </div>
                    <h5 class="mb-0">Сообщество</h5>
                </div>
                <p>Объединяет людей с общими интересами, чтобы делиться опытом и получать поддержку.</p>
            </div>
        </div>
        <!-- Блок 2: преимущества или особенности сайта -->
        <div class="col-md-6">
            <div class="card h-100 p-4 shadow-sm rounded border-0">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:50px; height:50px;">
                        <i class="bi bi-chat-dots-fill fs-4"></i>
                    </div>
                    <h5 class="mb-0">Общение</h5>
                </div>
                <p>Интерактивные чаты, форумы и мероприятия для активного взаимодействия.</p>
            </div>
        </div>
    </div>
</section>

<!-- Раздел с новостями или актуальной информацией -->
<section class="container mt-5">
    <h2 class="mb-4 text-center">Это интересно!</h2>
    <div class="row g-4">
        <!-- Карточка новости 1 -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm rounded">
                <img src="/photo/Главная_707.jpg" class="card-img-top" alt="Новость 1" />
                <div class="card-body">
                    <h5 class="card-title">Новость 1</h5>
                    <p class="card-text">С 1 января 2025 года продолжается работа по созданию центров общения старшего поколения на базе клиентских служб отделений Фонда в рамках реализации федерального проекта «Старшее поколение», входящего в национальный проект «Семья», и государственной программы Российской Федерации «Социальная поддержка граждан».</p>
                    <a href="/Account/News" class="btn btn-primary">Подробнее</a> 
                </div>
            </div>
        </div>
        <!-- Карточка новости 2 -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm rounded">
                <img src="/photo/Главная_85.jpg" class="card-img-top" alt="Новость 2" />
                <div class="card-body">
                    <h5 class="card-title">Новость 2</h5>
                    <p class="card-text">В преддверии Нового года на базе клиентской службы СФР в Энгельсском районе Саратовской области открылся Центр общения старшего поколения. Для нашего региона он стал четвертым по счету и очень долгожданным для активных, энергичных и талантливых представителей «серебряного» возраста из Энгельса.</p>
                    <a href="/Account/Login" class="btn btn-primary">Подробнее</a>
                </div>
            </div>
        </div>
        <!-- Карточка новости 3 -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm rounded">
                <img src="/photo/Главная_107.jpg" class="card-img-top" alt="Новость 3" />
                <div class="card-body">
                    <h5 class="card-title">Новость 3</h5>
                    <p class="card-text">Это новое пространство для развития, общения, образования и самореализации. Здесь, в наших гостеприимных стенах, представители серебряного возраста могут интересно и полезно провести время, получить новые знания, раскрыть в себе творческие таланты и обрести новых друзей»</p>
                    <a href="/Account/Login" class="btn btn-primary">Подробнее</a>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- Подписка на новости или форма обратной связи -->
<section class="bg-light py-5 mt-5">
    <div class="container text-center">
        <h2>Подписка на новости</h2>
        <p class="mb-4">Оставайтесь в курсе последних событий, подписавшись на нашу рассылку.</p>
        <form id="subscribeForm" class="row justify-content-center" style="max-width: 600px;">
            <div class="col-8 mb-3">
                <input type="email" class="form-control form-control-lg" placeholder="Ваш email" required />
            </div>
            <div class="col-4 mb-3">
                <button type="submit" class="btn btn-primary btn-lg w-100">Подписаться</button>
            </div>
        </form>
    </div>
</section>

<script>
    document.getElementById('subscribeForm').addEventListener('submit', function(e) {
      e.preventDefault(); 
      window.location.href = 'https://vk.com/sfr.saratovskayaoblast'; 
    });
</script>




<!-- Секция с отзывами или кейсами -->
<section class="container mt-5">
    <h2 class="mb-4 text-center">Отзывы пользователей</h2>
    <div class="row g-4">
        <!-- Отзыв 1 -->
        <div class="col-md-4">
            <div class="card h-100 p-3 shadow rounded">
                <div class="d-flex align-items-center mb-3">
                 
                    <div>
                        <h6 class="mb-0">Иван Иванов</h6>
                        <small class="text-muted">Пользователь</small>
                    </div>
                </div>
                <p>"Очень доволен сайтом! Помог мне найти новых друзей."</p>
            </div>
        </div>
        <!-- Отзыв 2 -->
        <div class="col-md-4">
            <div class="card h-100 p-3 shadow rounded">
                <div class="d-flex align-items-center mb-3">
                  
                    <div>
                        <h6 class="mb-0">Мария Петрова</h6>
                        <small class="text-muted">Пользователь</small>
                    </div>
                </div>
                <p>"Очень удобно и просто! Рекомендую всем."</p>
            </div>
        </div>
        <!-- Отзыв 3 -->
        <div class="col-md-4">
            <div class="card h-100 p-3 shadow rounded">
                <div class="d-flex align-items-center mb-3">
                   
                    <div>
                        <h6 class="mb-0">Алексей Смирнов</h6>
                        <small class="text-muted">Пользователь</small>
                    </div>
                </div>
                <p>"Общение с единомышленниками — отличное занятие."</p>
            </div>
        </div>
    </div>
</section>

<!-- Подключение JS-библиотек и дополнительных скриптов -->
@section Scripts {
    <!-- Подключение Bootstrap JS Bundle (включая Popper) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Можно добавить свои скрипты -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            console.log('Главная страница загружена');
            // Можно добавить обработчики событий, анимации и др.
        });
    </script>
} *@


@* @page
@model IndexModel
@{
    ViewData["Title"] = "Главная";
    Layout = "_Layout";
}

<style>
    /* =========================
           HERO
        ========================= */
    .hero-modern {
        background: linear-gradient(135deg, #1c41b0, #8aa2ec);
        color: white;
        padding: 40px;
        border-radius: 20px;
        margin-top: 20px;
    }

        .hero-modern h1 {
            font-weight: 800;
        }

    /* =========================
           ПЛИТКИ РАЗДЕЛОВ
        ========================= */
    .section-card {
        border-radius: 18px;
        overflow: hidden;
        transition: 0.25s ease;
        height: 100%;
        border: none;
    }

        .section-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 35px rgba(0,0,0,0.15);
        }

    .section-img {
        height: 170px;
        object-fit: cover;
    }

    /* =========================
           ПРОФИЛЬ БЛОКИ
        ========================= */
    .profile-card {
        border-radius: 16px;
        box-shadow: 0 6px 25px rgba(0,0,0,0.08);
        padding: 20px;
        text-align: center;
        background: #fff;
        height: 100%;
    }

        .profile-card img {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            margin-bottom: 10px;
        }

    .profile-box {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-top: 20px;
    }

    @@media (max-width: 768px) {
        .profile-box

    {
        grid-template-columns: 1fr;
    }

    }
</style>

<!-- =========================
     HERO
========================= -->
<div class="hero-modern">
    <h1>Центр общения старшего поколения</h1>
    <p>Саратовская область • пространство для общения, развития и поддержки</p>
</div>

<!-- =========================
     ПРОФИЛЬ
========================= -->
