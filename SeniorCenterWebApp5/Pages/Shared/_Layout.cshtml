<!doctype html>
<html lang="ru">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] ?? "Веб-приложение")</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>

        :root {
            --primary-1: #1c41b0;
            --primary-6: #8aa3ed;
            --bg: #f1f5fe;
        }

        html, body {
            height: 100%;
            margin: 0;
            font-family: "Inter", Arial;
            background: var(--bg);
            transition: font-size 0.2s ease, transform 0.2s ease;
        }

        main {
            width: 100%;
            min-height: calc(100vh - 120px);
        }

        .content-wrapper {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }

        /* ========================= HEADER ========================= */

        .site-navbar {
            background: linear-gradient(90deg, var(--primary-1), var(--primary-6));
        }

        .site-brand {
            font-weight: 700;
            color: white !important;
        }

        .nav-link {
            color: #000 !important;
            font-weight: 500;
        }

            .nav-link:hover {
                color: #1c41b0 !important;
            }

        .dropdown-item:hover {
            background: #f1f5fe;
            color: #1c41b0;
        }

        footer {
            padding: 2rem;
            text-align: center;
            color: #6b7280;
        }

        /* =========================
                   МАСШТАБ (ПРАВИЛЬНЫЙ)
                ========================= */

        /* Обычный */
        body {
            font-size: 18px;
        }

            /* КРУПНЫЙ */
            body.font-medium {
                font-size: 21px;
            }

            /* ОЧЕНЬ КРУПНЫЙ (≈ 1.35x) */
            body.font-large {
                font-size: 24px;
            }

            /* Общая читаемость */
            body.font-medium,
            body.font-large {
                line-height: 1.7;
            }

                /* Заголовки */
                body.font-medium h1 {
                    font-size: 2.2em !important;
                }

                body.font-medium h2 {
                    font-size: 1.9em !important;
                }

                body.font-medium h3 {
                    font-size: 1.6em !important;
                }

                body.font-large h1 {
                    font-size: 2.6em !important;
                }

                body.font-large h2 {
                    font-size: 2.2em !important;
                }

                body.font-large h3 {
                    font-size: 1.8em !important;
                }

                /* текст */
                body.font-medium p,
                body.font-medium li {
                    font-size: 1.05em !important;
                }

                body.font-large p,
                body.font-large li {
                    font-size: 1.15em !important;
                }

                /* кнопки */
             /*    body.font-medium .btn {
                    font-size: 1.05rem !important;
                }

                body.font-large .btn {
                    font-size: 1.15rem !important;
                } */
                /* кнопки (кроме переключателя масштаба) */
                body.font-medium .btn:not(.font-size-toggle .btn) {
                    font-size: 1.05rem !important;
                }

                body.font-large .btn:not(.font-size-toggle .btn) {
                    font-size: 1.15rem !important;
                }

                /* меню */
                body.font-medium .nav-link {
                    font-size: 1.05rem !important;
                }

                body.font-large .nav-link {
                    font-size: 1.15rem !important;
                }

        /* кнопка переключения */
        .font-size-toggle {
            position: fixed;
            top: 10px;
            right: 10px;
            z-index: 9999;
            width: 180px; /* фиксируем компактный размер */
        }

        /* убираем визуальный зазор */
        .btn-no-gap {
            margin-top: -2px; /* убирает линию/разрыв между блоками */
            border-top-left-radius: 0;
            border-top-right-radius: 0;
        }

        /* кнопки размера текста */

.font-btn-small {
    font-size: 14px;
    font-weight: 600;
}

.font-btn-medium {
    font-size: 18px;
    font-weight: 600;
}

.font-btn-large {
    font-size: 24px;
    font-weight: 600;
}

       
    </style>
</head>

<body>

    

    <!-- КНОПКИ МАСШТАБА -->
    <div class="font-size-toggle">

        <div class="btn-group btn-group-sm d-flex gap-0">
            <button id="fontNormal" class="btn btn-outline-primary w-50 font-btn-small"> А </button>
            <button id="fontMedium" class="btn btn-outline-primary w-50  font-btn-medium"> А+ </button>
        </div>

        <button id="fontLarge" class="btn btn-outline-primary w-100 btn-no-gap font-btn-large">
              АА+
        </button>

    </div>


    <!-- HEADER -->
    <header class="site-navbar">
        <nav class="container navbar navbar-expand-lg">

            <a class="navbar-brand site-brand" asp-page="/Index">
                Центр общения старшего поколения
            </a>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Account/CenterInfo">О центре</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Account/Meropriatia">Мероприятия</a>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                            Разделы
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-page="/Account/HobbyTest">Тест</a></li>
                            <li><a class="dropdown-item" asp-page="/Account/AntiMoshenniki">Безопасность</a></li>
                            <li><a class="dropdown-item" asp-page="/Account/News">Новости</a></li>
                        </ul>
                    </li>

                </ul>
            </div>

        </nav>
    </header>

    <!-- MAIN -->
    <main>
        <div class="content-wrapper">
            @RenderBody()
        </div>
    </main>

    <!-- FOOTER -->
    <footer>
        © @DateTime.Now.Year Центр общения старшего поколения
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- МАСШТАБ -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {

            const body = document.body;
           

            const normal = document.getElementById('fontNormal');
            const medium = document.getElementById('fontMedium');
            const large = document.getElementById('fontLarge');

            function set(mode) {
                body.classList.remove('font-medium', 'font-large');

                if (mode === 'medium') {
                    body.classList.add('font-medium');
                }

                if (mode === 'large') {
                    body.classList.add('font-large');
                }



                localStorage.setItem('font', mode);
            }

            normal.addEventListener('click', () => set('normal'));
            medium.addEventListener('click', () => set('medium'));
            large.addEventListener('click', () => set('large'));

            const saved = localStorage.getItem('font') || 'normal';
            set(saved);
        });
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>