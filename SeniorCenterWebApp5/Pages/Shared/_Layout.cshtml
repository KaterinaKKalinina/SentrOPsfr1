
@* <!doctype html>
<html lang="ru">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] ?? "Веб-приложение")</title>

    <!-- Шрифт -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        :root {
            --primary-1: #1c41b0;
            --primary-2: #8aa2ec;
            --primary-3: #f1f5fe;
            --primary-6: #8aa3ed;
            --primary-7: #153084;
            --primary-4: #822828;
            --primary-5: #cf6363;
            --card-radius: 14px;
            --max-width: 1100px;
            --font-size: 1rem;
        }

        html, body {
            height: 100%;
            margin: 0;
            font-family: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, Arial;
            background: var(--primary-3);
            color: #0b0b0b;
            font-size: var(--font-size, 1rem);
        }

            body.font-large {
                --font-size: 1.7rem;
            }

        .font-size-toggle {
            position: fixed;
            top: 10px;
            right: 10px;
            z-index: 1050;
        }

        .site-navbar {
            background: linear-gradient(80deg, var(--primary-1) 20%, var(--primary-6) 70%);
            box-shadow: 0 1px 0 rgba(11,11,11,0.04);
        }

        .site-brand {
            font-weight: 700;
            color: #ffffff;
        }

        /* ЧЕРНЫЙ ТЕКСТ МЕНЮ */
        .nav-link {
            color: #000 !important;
        }

        .dropdown-item {
            color: #000;
        }

        .nav-link:hover {
            opacity: 0.75;
        }

        footer.site-footer {
            padding: 2rem 1rem;
            text-align: center;
            color: #6b7280;
            font-size: .9rem;
        }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body>

    <!-- Переключатель размера -->
    <div class="font-size-toggle btn-group btn-group-sm">
        <button id="fontNormal" class="btn btn-outline-primary">Стандартный</button>
        <button id="fontLarge" class="btn btn-outline-primary">Увеличенный</button>
    </div>

    <!-- ШАПКА -->
    <header class="site-navbar">
        <nav class="container navbar navbar-expand-lg navbar-light">

            <a class="navbar-brand site-brand" asp-page="/Index">
                Центр общения старшего поколения
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto align-items-lg-center">

                    <!-- О нас -->
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Account/CenterInfo">О нас</a>
                    </li>

                    <!-- Мероприятия -->
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Account/Meropriatia">Мероприятия</a>
                    </li>

                    <!-- Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            Разделы
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end">

                            <li>
                                <a class="dropdown-item" asp-page="/Account/News">Новости</a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-page="/Account/HobbyTest">Тест</a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-page="/Account/AntiMoshenniki">
                                    Противодействие мошенникам
                                </a>
                            </li>

                        </ul>
                    </li>

                </ul>
            </div>
        </nav>
    </header>

    <!-- Контент -->
    <main role="main" class="mb-5">
        @RenderBody()
    </main>

    <!-- Футер -->
    <footer class="site-footer">
        <div class="container">
            <small>&copy; @(DateTime.Now.Year) Центр общения старшего поколения</small>
        </div>
    </footer>

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const body = document.body;
            const btnNormal = document.getElementById('fontNormal');
            const btnLarge = document.getElementById('fontLarge');

            if (localStorage.getItem('fontSize') === 'large') {
                body.classList.add('font-large');
            }

            btnNormal.addEventListener('click', () => {
                body.classList.remove('font-large');
                localStorage.setItem('fontSize', 'normal');
            });

            btnLarge.addEventListener('click', () => {
                body.classList.add('font-large');
                localStorage.setItem('fontSize', 'large');
            });
        });
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>


 *@


