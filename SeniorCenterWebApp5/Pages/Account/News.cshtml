@* @page
@model SeniorCenterWebApp.Pages.Account.NewsModel

<!-- HEADER -->
<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">Новости</h1>
        <p class="lead text-muted fs-5">
            Актуальная информация для старшего поколения Саратовской области
        </p>
    </div>

    <div class="search-box text-center mb-4">
        <form method="get">
            <input type="text" name="Search" placeholder="Поиск..." />
            <button type="submit">Найти</button>
        </form>
    </div>

</div>

<!-- LAYOUT -->
<div class="layout">

    <!-- SIDEBAR -->
    <aside class="categories">

        <h4>Категории</h4>

        <!-- ВСЕ -->
        <a class="category-link @(string.IsNullOrEmpty(Model.SelectedCategory) ? "active" : "")"
           href="/Account/News">
            Все
        </a>

        @foreach (var cat in Model.Categories)
        {
            <a class="category-link @(Model.SelectedCategory == cat ? "active" : "")"
               href="/Account/News?SelectedCategory=@cat">
                @cat
            </a>
        }

    </aside>

    <!-- CONTENT -->
    <main class="news-container">

        @foreach (var news in Model.NewsList)
        {
            <div class="news-card">

                <div class="news-img-wrapper">
                    @if (!string.IsNullOrEmpty(news.ImageUrl))
                    {
                        <img src="@news.ImageUrl" />
                    }
                </div>

                <div class="news-content">

                    <h5 class="text-primary fs-4 mb-2">
                        @news.Title
                    </h5>

                    <small class="text-muted d-block mb-2">
