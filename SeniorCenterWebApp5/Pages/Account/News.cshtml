            margin: 6px 0;
            font-size: 1.05rem;
        }

    /* ПОИСК */
    .search-box {
        margin-bottom: 30px;
        text-align: center;
    }

        .search-box input {
            width: 300px;
            padding: 10px;
            font-size: 1.05rem;
            border-radius: 8px;
            border: 1px solid #ccc;
        }

        .search-box button {
            padding: 10px 20px;
            font-size: 1.05rem;
            border-radius: 8px;
            border: none;
            background-color: #42a5f5;
            color: white;
            font-weight: 600;
            margin-left: 10px;
        }

            .search-box button:hover {
                background-color: #1e88e5;
            }
</style>

