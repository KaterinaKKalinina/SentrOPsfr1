@page
@model SeniorCenterWebApp.Pages.Account.NewsModel
@{
    ViewData["Title"] = "Новости";
}

<style>

    body {
        margin: 0;
        background: #f1f5fe;
        font-family: "Inter", "Segoe UI", Arial, sans-serif;
        color: #111;
    }

    .page {
        max-width: 1400px;
        margin: 0 auto;
        padding: 30px 20px 80px;
    }

    /* ========================= HERO ========================= */

    .hero-modern {
        background: linear-gradient(135deg, #1c41b0, #2f6bff);
        color: #fff;
        padding: 70px 40px;
        border-radius: 24px;
        margin: 20px auto 30px;
        text-align: center;
    }

        .hero-modern h1 {
            font-size: 40px;
            font-weight: 800;
            margin: 0;
        }

        .hero-modern p {
            font-size: 20px;
            opacity: 0.95;
            margin-top: 12px;
        }

    /* ========================= SEARCH ========================= */

    .search-box {
        display: flex;
        justify-content: center;
        margin-bottom: 25px;
    }

        .search-box input {
            width: 320px;
            padding: 12px 14px;
            border-radius: 12px;
            border: 1px solid #dbe6ff;
            outline: none;
            font-size: 16px;
        }

        .search-box button {
            margin-left: 10px;
            padding: 12px 18px;
            border-radius: 12px;
            border: none;
            background: #3884ff;
            color: #fff;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

            .search-box button:hover {
                background: #0041aa;
            }

    /* ========================= LAYOUT ========================= */

    .layout {
        display: flex;
        gap: 20px;
    }

    /* ========================= SIDEBAR ========================= */

    .categories {
        width: 260px;
        background: #1c41b0;
        color: white;
        padding: 20px;
        border-radius: 18px;
        height: fit-content;
    }

        .categories h4 {
            margin-top: 0;
            font-size: 20px;
            font-weight: 800;
            margin-bottom: 15px;
        }

    .category-link {
        display: block;
        padding: 10px 12px;
        border-radius: 12px;
        color: white;
        text-decoration: none;
        margin-bottom: 8px;
        transition: 0.2s;
        font-weight: 600;
    }

        .category-link:hover {
            background: rgba(255,255,255,0.15);
        }

        .category-link.active {
            background: #fff;
            color: #1c41b0;
        }

    /* ========================= NEWS ========================= */

    .news-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .news-card {
        background: #fff;
        border-radius: 18px;
        overflow: hidden;
        display: flex;
        box-shadow: 0 6px 18px rgba(0,0,0,0.06);
        border: 1px solid #e7eef8;
        transition: 0.2s;
    }

        .news-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 14px 35px rgba(0,0,0,0.12);
        }

    .news-img {
        width: 280px;
        min-width: 280px;
        height: 220px;
        object-fit: cover;
        background: #f1f5fe;
    }

    .news-content {
        padding: 18px;
    }

    .news-title {
        font-size: 22px;
        font-weight: 800;
        color: #1c41b0;
        margin-bottom: 8px;
    }

    .news-date {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 10px;
    }

    .news-desc {
        font-size: 16px;
        color: #333;
        margin-bottom: 10px;
    }

    .news-category {
        font-size: 14px;
        font-weight: 600;
        color: #3884ff;
    }

    /* ========================= BUTTONS ========================= */

    .bottom-buttons {
        display: flex;
        gap: 16px;
        margin-top: 40px;
    }

    .btn-modern {
        flex: 1;
        padding: 14px;
        border-radius: 14px;
        text-align: center;
        font-weight: 700;
        text-decoration: none;
        font-size: 18px;
        transition: 0.2s;
        background: #3884ff;
        color: #fff;
    }

        .btn-modern:hover {
            background: #0041aa;
        }

    .btn-secondary {
        background: #ccdbff;
        color: #1c41b0;
    }

        .btn-secondary:hover {
            background: #dbe6ff;
        }

</style>

<div class="page">

    <!-- HERO -->
    <div class="hero-modern">
        <h1>Новости</h1>
        <p>Актуальная информация для старшего поколения</p>
    </div>

    <!-- SEARCH -->
    <div class="search-box">
        <form method="get">
            <input type="text" name="Search" placeholder="Поиск новостей..." />
            <button type="submit">Найти</button>
        </form>
    </div>

    <!-- LAYOUT -->
    <div class="layout">

        <!-- SIDEBAR -->
        <aside class="categories">

            <h4>Категории</h4>

            <a class="category-link @(string.IsNullOrEmpty(Model.SelectedCategory) ? "active" : "")"
               href="/Account/News">
                Все
            </a>

            @foreach (var cat in Model.Categories)
            {
                <a class="category-link @(Model.SelectedCategory == cat ? "active" : "")"
                   href="/Account/News?SelectedCategory=@cat">
                    @cat
                </a>
            }

        </aside>

        <!-- NEWS -->
        <main class="news-container">

            @foreach (var news in Model.NewsList)
            {
                <div class="news-card">

                    @if (!string.IsNullOrEmpty(news.ImageUrl))
                    {
                        <img class="news-img" src="@news.ImageUrl" />
                    }

                    <div class="news-content">

                        <div class="news-title">@news.Title</div>

                        <div class="news-date">
                            @news.PublishDate.ToShortDateString()
                        </div>

                        <div class="news-desc">
                            @news.Description
                        </div>

                        <div class="news-category">
                            Категория: @news.Category
                        </div>

                    </div>

                </div>
            }

        </main>

    </div>

    <!-- BUTTONS -->
    <div class="bottom-buttons">

        <a class="btn-modern btn-secondary" asp-page="/Account/AntiMoshenniki">
            Назад
        </a>

        <a class="btn-modern" asp-page="/Index">
            На главную
        </a>

    </div>

</div>