@* @page
@model SeniorCenterWebApp.Pages.Account.NewsModel

<h2>Новости</h2>

<!-- Фильтр как у мероприятий -->
<form method="get">
    <label>Фильтр по типу:</label>

    <select asp-for="SelectedCategory">
        <option>Все</option>

        @foreach (var cat in Model.Categories)
        {
            <option value="@cat">@cat</option>
        }
    </select>

    <button type="submit">Применить</button>
</form>

<br />

<table border="1" cellpadding="10">
    <thead>
        <tr>
            <th>Название</th>
            <th>Описание</th>
            <th>Фото</th>
            <th>Дата</th>
            <th>Тип</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var news in Model.NewsList)
        {
            <tr>
                <td>@news.Title</td>

                <td>@news.Description</td>

                <td>
                    @if (!string.IsNullOrEmpty(news.ImageUrl))
                    {
                        <img src="@news.ImageUrl" width="120" />
                    }
                </td>

                <td>@news.PublishDate.ToShortDateString()</td>

                <td>@news.Category</td>
            </tr>
        }
    </tbody>
</table> *@

