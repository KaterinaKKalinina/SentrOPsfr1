
@* @page
@model SeniorCenterWebApp.Pages.Account.MeropriatiaModel
@{
    ViewData["Title"] = "Мероприятия";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">Мероприятия</h1>
        <p class="lead text-muted fs-5">
            Здесь вы можете выбрать интересующее вас мероприятие, записаться и следить за свободными местами.
        </p>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-info fs-5">
            @Model.Message
        </div>
    }

    <!-- Фильтр по району без кнопки -->
    <form method="get" id="districtForm" class="mb-4 text-center">
        <label class="form-label fw-bold me-2 fs-5">Фильтр по району:</label>
        <select asp-for="SelectedDistrict" asp-items="@(new SelectList(Model.Districts.Prepend("Все")))"
                class="form-select d-inline-block w-50 fs-5 py-2" onchange="this.form.submit()">
        </select>
    </form>

    <div class="row g-4">
        @foreach (var m in Model.Meroprs)
        {
            var taken = m.UserMeroprs.Count;
            var free = m.MaxParticipants - taken;

            <div class="col-md-4">
                <div class="card shadow-sm border-0 rounded-3">
                    @if (!string.IsNullOrEmpty(m.ImageUrl))
                    {
                        <img class="card-img-top rounded-3" src="@m.ImageUrl" style="height:220px; object-fit:cover;" alt="@m.Title">
                    }
                    <div class="card-body d-flex flex-column fs-5">
                        <!-- Заголовок по центру -->
                        <h5 class="card-title text-primary fs-4 text-center">@m.Title</h5>
                        <!-- Описание по центру -->
                        <p class="card-text description text-center">@m.Description</p>

                        <!-- Остальной текст по левому краю -->
                        <div class="text-start mt-2">
                            <p class="card-text">
                                <i class="bi bi-geo-alt-fill icon me-2"></i>@m.District
                            </p>
                            <p class="card-text">
                                <i class="bi bi-calendar-event icon me-2"></i>
                                @(m.EventDate?.ToString("dd MMMM yyyy") ?? m.DayOfWeek)
                                <br />
                                <i class="bi bi-clock-fill icon me-2"></i>
                                @(m.EventTime?.ToString(@"hh\:mm") ?? "-")
                            </p>
                            <p class="card-text"><strong>Свободные места:</strong> @free из @m.MaxParticipants</p>
                        </div>

                        <form method="post" asp-page-handler="Register" class="mt-auto">
                            <input type="hidden" name="meroprId" value="@m.Id" />
                            <button type="submit" class="btn btn-primary @(free == 0 ? "disabled" : "") fs-5 py-2">
                                Записаться
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Основной стиль карточек */
    .card {
        border-radius: 15px;
        background-color: #ffffff;
    }

    /* Заголовок по центру */
    .card-title {
        font-weight: 600;
        text-align: center;
    }

    /* Описание по центру и серым цветом */
    .card-text.description {
        color: #6c757d; /* серый Bootstrap */
        text-align: center;
    }

    /* Иконки серого цвета */
    .card-text .icon {
        color: #6c757d;
    }

    /* Остальные параграфы по левому краю */
    .card-body .text-start p {
        margin-bottom: 0.75rem;
    }

    /* Кнопка "Записаться" */
    .btn-primary {
        background-color: #42a5f5;
        border-color: #42a5f5;
        font-weight: 600;
    }

        .btn-primary:hover {
            background-color: #1e88e5;
            border-color: #1e88e5;
        }

    .alert-info {
        background-color: #bbdefb;
        border-color: #90caf9;
        color: #0d47a1;
    }

    /* Увеличенный шрифт для выпадающего списка */
    select.form-select {
        font-size: 1.2rem;
    }
</style>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
}



