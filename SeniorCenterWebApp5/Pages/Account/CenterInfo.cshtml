
@* 
@page
@using Microsoft.AspNetCore.Authorization



@model CenterInfoModel
@{
    ViewData["Title"] = "Информация о центре";
}
<!-- Основной фон и центрирование -->
<div class="container py-5">
    <div class="text-center mb-4">
        <h1 class="display-4 fw-bold text-primary">Информация о центре</h1>
        <p class="lead text-muted mt-3">
            Центр общения старшего поколения — место, где пожилые люди могут общаться,<br />
            участвовать в занятиях по интересам, получать психологическую и социальную поддержку.<br />
            Наша цель — создать тёплую, безопасную и активную среду для общения и развития.
        </p>
    </div>

    <!-- Раздел "Чем мы занимаемся" -->
    <div class="card shadow-sm mb-5 p-4 rounded-3 bg-light">
        <h2 class="h3 mb-3 text-secondary"><i class="bi bi-people-fill me-2"></i>Чем мы занимаемся</h2>
        <ul class="list-group list-group-flush">
            <li class="list-group-item"><i class="bi bi-calendar-event-fill text-primary me-2"></i>Клубные встречи и творческие мастер-классы</li>
            <li class="list-group-item"><i class="bi bi-activity text-primary me-2"></i>Физические упражнения и прогулки на свежем воздухе</li>
            <li class="list-group-item"><i class="bi bi-heart-fill text-primary me-2"></i>Психологическая поддержка и консультации</li>
            <li class="list-group-item"><i class="bi bi-laptop-fill text-primary me-2"></i>Обучающие занятия по цифровой грамотности</li>
        </ul>
    </div>

    <!-- Галерея изображений -->
    <section class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <img src="@Url.Content("/photo/Инф_о_центре_ТАНЦЫ.png")" class="card-img-top img-fluid rounded-3" style="max-height:420px; object-fit:cover;" alt="Группа пожилых людей на занятии" />
                <div class="card-body p-3">
                    <p class="card-text text-center text-muted">Мастер-класс по танцам для участников центра.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <img src="@Url.Content("/photo/Инф_о_центре_СИДЯТ.png")" class="card-img-top img-fluid rounded-3" style="max-height:420px; object-fit:cover;" alt="Две женщины разговаривают за чаепитием" />
                <div class="card-body p-3">
                    <p class="card-text text-center text-muted">Дружеские беседы за чаем и обмен опытом.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Контакты и расписание -->
    <div class="card shadow-sm p-4 rounded-3 bg-light">
        <h2 class="h3 mb-3 text-secondary"><i class="bi bi-geo-alt-fill me-2"></i>Контакты и расписание</h2>
        <p class="mb-2"><i class="bi bi-geo-alt-fill me-2"></i>Адрес: 410004, Саратовская область, г. Саратов, ул. Е.И. Пугачева, д.11/13</p>
        <p class="mb-2"><i class="bi bi-telephone-fill me-2"></i>Телефон: +7 (800) 100-00-01</p>
        <p class="mb-2"><i class="bi bi-clock-fill me-2"></i>Работаем: Пн-Чт 08:00-17:00, Пт 08:00-16:00</p>
    </div>


    <div class="text-center mb-5">
      
        <a href="/Account/Meropriatia" class="btn btn-primary btn-lg shadow-lg px-4 py-3" style="border-radius: 50px; font-weight: 600;">
            Далее <i class="bi bi-arrow-right-circle ms-2"></i>
        </a>
    </div>
</div>



<!-- Подключение Bootstrap и Bootstrap Icons -->
@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
} *@


