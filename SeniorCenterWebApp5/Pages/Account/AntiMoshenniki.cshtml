


@* @page
@model SeniorCenterWebApp.Pages.Account.AntiMoshennikiModel
@{
    ViewData["Title"] = "Противодействие мошенничеству";
}
<style>
    /* Изменение стиля h2 */
    h2 {
       
        color: #153084;
    }
    /* Цвет ссылок внизу */
    .bottom-links a {
        color: #000000;
    }
</style>
<div class="container py-5 bg-light rounded shadow-sm">
    <h1 class="text-center mb-4 display-3 fw-bold text-primary">
        <i class="bi me-3"></i> Как защититься от мошенников
    </h1>
    <p class="lead text-center mb-5 text-muted">
        <i class="bi me-2"></i> Мошенники используют различные схемы для обмана и выманивания денег. Ниже представлены самые распространённые схемы и советы по их распознаванию.
    </p>

    <!-- Распространённые схемы -->
    <section class="mb-5">
        <h2 class="mb-4 border-bottom pb-2 d-flex align-items-center">
            <i class="bi me-3"></i> Наиболее распространённые схемы мошенничества
        </h2>
        <div class="row g-4 mt-3">
            <div class="col-md-6">
                <div class="card h-100 border-primary shadow-sm">
                    <div class="card-body d-flex align-items-start">
                        <i class="bi bi-envelope-fill text-primary fs-3 me-3"></i>
                        <div>
                            <h5 class="card-title mb-2">Фишинг</h5>
                            <p class="card-text mb-0">попытки заставить вас раскрыть личные данные через поддельные сайты или письма.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 border-primary shadow-sm">
                    <div class="card-body d-flex align-items-start">
                        <i class="bi bi-telephone-fill text-primary fs-3 me-3"></i>
                        <div>
                            <h5 class="card-title mb-2">Мошенничество по телефону</h5>
                            <p class="card-text mb-0">звонки от "представителей банка" или "правоохранительных органов", требующие деньги или личные данные.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 border-primary shadow-sm">
                    <div class="card-body d-flex align-items-start">
                        <i class="bi bi-shield-lock-fill text-primary fs-3 me-3"></i>
                        <div>
                            <h5 class="card-title mb-2">Поддельные интернет-магазины</h5>
                            <p class="card-text mb-0">сайты, предлагающие товары по очень низким ценам, но не выполняющие доставку.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 border-primary shadow-sm">
                    <div class="card-body d-flex align-items-start">
                        <i class="bi bi-trophy-fill text-primary fs-3 me-3"></i>
                        <div>
                            <h5 class="card-title mb-2">Лотереи и выигрыши</h5>
                            <p class="card-text mb-0">уведомления о выигрыше и требования оплатить "налог" или "комиссию".</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 border-primary shadow-sm">
                    <div class="card-body d-flex align-items-start">
                        <i class="bi bi-people-fill text-primary fs-3 me-3"></i>
                        <div>
                            <h5 class="card-title mb-2">Манипуляции в соцсетях</h5>
                            <p class="card-text mb-0">мошенники создают фальшивые аккаунты для обмана.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Что делать -->
    <section class="mb-5">
        <h2 class="mb-4 border-bottom pb-2 d-flex align-items-center">
            <i class="bi bi-shield-check-fill me-3"></i> Что делать, чтобы защититься
        </h2>
        <ul class="list-group list-group-flush mt-3">
            <li class="list-group-item"><i class="bi bi-lock-fill text-primary me-2"></i> Не раскрывайте личную информацию и пароли.</li>
            <li class="list-group-item"><i class="bi bi-search-heart-fill text-primary me-2"></i> Проверяйте сайты и контакты на подлинность.</li>
            <li class="list-group-item"><i class="bi  bi-info-circle-fill text-primary me-2"></i> Не переводите деньги незнакомым людям или по сомнительным схемам.</li>
            <li class="list-group-item"><i class="bi bi-telephone-fill text-primary me-2"></i> Обращайтесь в официальные службы при подозрениях.</li>
        </ul>
    </section>

    <!-- Видео -->
    <section class="mb-5">
        <h2 class="mb-4 border-bottom pb-2 d-flex align-items-center">
            <i class="bi me-3"></i> Видео: Как распознать мошенничество
        </h2>
        <div class="d-flex justify-content-center">
            <video class="w-75 rounded shadow" controls>
                <source src="@Url.Content("/photo/video_protiv1.mp4")" type="video/mp4" />
                Ваш браузер не поддерживает тег видео.
            </video>
        </div>
    </section>

    <!-- Полезные ресурсы -->
    <section>
        <h2 class="mb-4 border-bottom pb-2 d-flex align-items-center">
            <i class="bi me-3"></i> Полезные ресурсы
        </h2>
        <ul class="list-unstyled mt-3 bottom-links">
            <li class="mb-2">
                <a href="https://sfr.gov.ru/projects/moshenniki_v_socialnom_sektore/?sortbydate=up" class="text-decoration-none fs-5">
                    <i class="bi bi-link-45deg me-2"></i> Социальный фонд России предлагает ознакомиться с типичными схемами мошенников
                </a>
            </li>
       
            <li class="mb-2">
                <a href="/pdf_ckach/ПДФ_Против_Мошенников_читать.pdf" class="text-decoration-none fs-5" download>
                    <i class="bi bi-file-earmark-pdf-fill me-2"></i> Скачать инструкцию (PDF)
                </a>
            </li>
        </ul>
    </section>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
}
