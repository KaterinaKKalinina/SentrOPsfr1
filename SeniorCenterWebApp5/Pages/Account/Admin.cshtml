
@page
@model SeniorCenterWebApp.Pages.Account.AdminModel
@{
    ViewData["Title"] = "Панель администратора";
}

<h1 class="mt-4 mb-4">Панель администратора</h1>

<!-- Поиск -->
<form method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="SearchString" class="form-control" placeholder="Поиск по имени или email" value="@Model.SearchString" />
        <button class="btn btn-primary" type="submit">Найти</button>
    </div>
</form>

<!-- Добавление нового пользователя -->
<section class="mb-5">
    <h2>Добавить пользователя</h2>
    <form method="post" class="row g-3">
        <div class="col-md-4">
            <input asp-for="NewUser.Username" class="form-control" placeholder="Имя пользователя" />
        </div>
        <div class="col-md-4">
            <input asp-for="NewUser.Email" class="form-control" placeholder="Email" />
        </div>
        <div class="col-md-4">
            <input asp-for="NewUser.FullName" class="form-control" placeholder="ФИО" />
        </div>
        <div class="col-md-4">
            <input asp-for="NewUser.PasswordHash" class="form-control" placeholder="Пароль" type="password" />
        </div>
        <div class="col-md-4">
            <input asp-for="NewUser.DateOfBirth" class="form-control" type="date" />
        </div>
        <div class="col-md-12">
            <button type="submit" class="btn btn-success">Добавить пользователя</button>
        </div>
    </form>
</section>

<!-- Таблица пользователей -->
<section class="mb-5">
    <h2>Пользователи</h2>
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Имя</th>
                <th>Пароль</th>
                <th>Email</th>
                <th>ФИО</th>
                <th>Дата регистрации</th>
                <th>Дата рождения</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Username</td>
                    <td>@user.PasswordHash</td>
                    <td>@user.Email</td>
                    <td>@user.FullName</td>
                    <td>@user.RegistrationDate.Date.ToString("dd.MM.yyyy")</td>
                    <td>@user.DateOfBirth.Date.ToString("dd.MM.yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</section>

<!-- Таблица результатов тестов -->
<section>
    <h2>Результаты тестов</h2>
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>ID теста</th>
                <th>Пользователь</th>
                <th>Дата прохождения</th>
                <th>Результат</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var result in Model.TestResults)
            {
                <tr>
                    <td>@result.Id</td>
                    <td>@result.User.Username</td>
                    <td>@result.DateTaken.Date.ToString("dd.MM.yyyy")</td>
                    <td>@result.HobbyResult</td>
                </tr>
            }
        </tbody>
    </table>
</section>