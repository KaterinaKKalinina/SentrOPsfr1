@page
@model SeniorCenterWebApp.Pages.Account.Vostanovl.ResetPasswordConfirmationModel

@{
    ViewData["Title"] = "Готово";
}

<div class="d-flex align-items-center justify-content-center min-vh-100"
     style="background: var(--primary-3);">

    <div class="card shadow-lg rounded-4 p-4 text-center" style="max-width: 400px; width: 100%;">
        <h2 class="fw-bold text-primary mb-3">
            <i class="bi bi-check-circle"></i> Пароль изменён
        </h2>

        <p class="text-muted">
            Теперь вы можете войти с новым паролем.
        </p>

        <a asp-page="/Account/Login" class="btn btn-primary rounded-pill mt-3">
            Войти
        </a>
    </div>
</div>